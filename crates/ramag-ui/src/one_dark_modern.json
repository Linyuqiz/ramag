{
  "$schema": "https://github.com/longbridge/gpui-component/raw/refs/heads/main/.theme-schema.json",
  "name": "One Dark Modern",
  "author": "Ramag (Dark Modern UI + One Dark Pro syntax)",
  "url": "https://github.com/aleksa-codes/one-dark-modern-pro",
  "themes": [
    {
      "name": "One Dark Modern",
      "mode": "dark",
      "colors": {
        "background": "#1f1f1f",
        "foreground": "#cccccc",
        "border": "#2b2b2b",
        "ring": "#0078d4",
        "caret": "#cccccc",
        "accent.background": "#2a2d2e",
        "accent.foreground": "#ffffff",
        "input.border": "#3c3c3c",
        "primary.background": "#0078d4",
        "primary.active.background": "#026ec1",
        "primary.foreground": "#ffffff",
        "secondary.background": "#181818",
        "secondary.foreground": "#cccccc",
        "secondary.hover.background": "#2a2d2e",
        "secondary.active.background": "#313131",
        "muted.background": "#313131",
        "muted.foreground": "#9d9d9d",
        "popover.background": "#1f1f1f",
        "popover.foreground": "#cccccc",
        "panel.background": "#181818",
        "sidebar.background": "#181818",
        "sidebar.foreground": "#cccccc",
        "sidebar.border": "#2b2b2b",
        "title_bar.background": "#181818",
        "title_bar.border": "#2b2b2b",
        "tab_bar.background": "#181818",
        "tab.active.background": "#1f1f1f",
        "tab.active.foreground": "#ffffff",
        "tab.background": "#181818",
        "tab.foreground": "#9d9d9d",
        "list.active.background": "#04395e",
        "list.active.border": "#0078d4",
        "list.even.background": "#1f1f1f",
        "list.head.background": "#181818",
        "link.foreground": "#4daafc",
        "link.hover.foreground": "#4daafc",
        "selection.background": "#264f78",
        "scrollbar.background": "#1f1f1f00",
        "scrollbar.thumb.background": "#4e4e4e",
        "danger.background": "#f85149",
        "danger.foreground": "#ffffff",
        "success.background": "#89d185",
        "success.foreground": "#1f1f1f",
        "warning.background": "#cca700",
        "warning.foreground": "#1f1f1f",
        "info.background": "#0078d4",
        "info.foreground": "#ffffff",
        "base.red": "#e06c75",
        "base.green": "#98c379",
        "base.yellow": "#e5c07b",
        "base.blue": "#61afef",
        "base.blue.light": "#7cc0f5",
        "base.magenta": "#c678dd",
        "base.cyan": "#56b6c2"
      },
      "highlight": {
        "editor.foreground": "#cccccc",
        "editor.background": "#1f1f1f",
        "editor.active_line.background": "#2a2a2a",
        "editor.line_number": "#6e7681",
        "editor.active_line_number": "#cccccc",
        "syntax": {
          "keyword": { "color": "#c678dd" },
          "keyword.import": { "color": "#c678dd" },
          "keyword.return": { "color": "#c678dd" },
          "keyword.function": { "color": "#c678dd" },
          "keyword.operator": { "color": "#c678dd" },
          "keyword.conditional": { "color": "#c678dd" },
          "keyword.repeat": { "color": "#c678dd" },
          "string": { "color": "#98c379" },
          "string.escape": { "color": "#56b6c2" },
          "string.regexp": { "color": "#56b6c2" },
          "string.special": { "color": "#56b6c2" },
          "character": { "color": "#98c379" },
          "function": { "color": "#61afef" },
          "function.call": { "color": "#61afef" },
          "function.method": { "color": "#61afef" },
          "function.builtin": { "color": "#56b6c2" },
          "constructor": { "color": "#e5c07b" },
          "type": { "color": "#e5c07b" },
          "type.builtin": { "color": "#e5c07b" },
          "type.parameter": { "color": "#e5c07b" },
          "module": { "color": "#e5c07b" },
          "constant": { "color": "#d19a66" },
          "constant.builtin": { "color": "#d19a66" },
          "number": { "color": "#d19a66" },
          "number.float": { "color": "#d19a66" },
          "boolean": { "color": "#d19a66" },
          "variable": { "color": "#e06c75" },
          "variable.builtin": { "color": "#e06c75" },
          "variable.parameter": { "color": "#cccccc" },
          "variable.member": { "color": "#e06c75" },
          "property": { "color": "#e06c75" },
          "label": { "color": "#61afef" },
          "comment": { "color": "#7f848e", "font_style": "italic" },
          "comment.doc": { "color": "#7f848e", "font_style": "italic" },
          "operator": { "color": "#56b6c2" },
          "punctuation": { "color": "#cccccc" },
          "punctuation.bracket": { "color": "#cccccc" },
          "punctuation.delimiter": { "color": "#cccccc" },
          "punctuation.special": { "color": "#56b6c2" },
          "tag": { "color": "#e06c75" },
          "attribute": { "color": "#d19a66" }
        }
      }
    }
  ]
}
